# torhole — environment configuration
# Copy to .env and fill all CHANGE_ME values before running deploy.sh.
#
#   cp .env.example .env
#   nano .env

# Capability profile. Existing full-stack deployments should use advanced;
# the unified installer uses home unless the operator opts into this stack.
TORHOLE_EDITION=advanced

# Advanced topology is independent from the edition:
#   single-lan = one flat-LAN Pi-hole/dnscrypt plane plus the full Advanced
#                operations stack (SSO, Grafana, Prometheus, Loki, alerts)
#   vlan       = Trusted + IoT Pi-hole/dnscrypt planes on segmented networks
# Existing Advanced installs that pre-date this key default to vlan.
TORHOLE_TOPOLOGY=vlan

# Curated Pi-hole gravity sources selected by the guided installer.
# Values: stevenblack,oisd,adguard (comma-separated, at least one).
# Advanced applies the same selection to every active DNS plane.
TORHOLE_BLOCKLISTS=stevenblack

# Your timezone (e.g. Europe/London, America/New_York, Asia/Tokyo)
TZ=UTC

# Physical interface connected to your managed switch trunk
PARENT_IF=eth0

# Management IP of the Pi / VM on the Trusted LAN.
# Used for output messages and optional host firewall rules.
HOST_MGMT_IP=CHANGE_ME   # e.g. 192.168.1.10

# VLAN IDs — match your router/switch configuration
TRUSTED_VLAN_ID=1
IOT_VLAN_ID=50

# Parent interfaces for Docker macvlan networks.
# UniFi note: VLAN 1 is often the untagged/native LAN.
#   Untagged (common): TRUSTED_PARENT=eth0
#   Tagged:            TRUSTED_PARENT=eth0.1
TRUSTED_PARENT=eth0
IOT_PARENT=eth0.50

# Network CIDRs and gateways — fill with your actual values
TRUSTED_SUBNET_CIDR=CHANGE_ME   # e.g. 192.168.1.0/24
TRUSTED_GATEWAY=CHANGE_ME       # e.g. 192.168.1.1
IOT_SUBNET_CIDR=CHANGE_ME       # e.g. 192.168.50.0/24
IOT_GATEWAY=CHANGE_ME           # e.g. 192.168.50.1

# Static IPs for each Pi-hole endpoint (must be free in each VLAN subnet)
PIHOLE_TRUSTED_IP=CHANGE_ME     # e.g. 192.168.1.53
PIHOLE_IOT_IP=CHANGE_ME         # e.g. 192.168.50.53

# Pi-hole admin passwords — used by the web UI and API
PIHOLE_TRUSTED_PASSWORD=CHANGE_ME
PIHOLE_IOT_PASSWORD=CHANGE_ME

# dnscrypt-proxy resolver selection
# Names from: https://github.com/DNSCrypt/dnscrypt-resolvers/blob/master/v3/public-resolvers.md
# See docs/resolvers.md for guidance on choosing resolvers.
DNSCRYPT_RESOLVERS=cloudflare-security,quad9-dnscrypt-ip4-filter-pri

# dnscrypt-proxy performance tuning
# Larger cache helps when Tor adds latency (default 8192 is a good starting point).
DNSCRYPT_CACHE_SIZE=8192
DNSCRYPT_CACHE_MIN_TTL=60
DNSCRYPT_CACHE_MAX_TTL=86400
DNSCRYPT_TIMEOUT_MS=5000
DNSCRYPT_KEEPALIVE_S=30

# Tor circuit isolation credentials
# Each VLAN gets separate SOCKS credentials, giving each its own Tor circuit.
# Use strong random passwords: openssl rand -base64 24
DNSCRYPT_SOCKS_USER_TRUSTED=trusted
DNSCRYPT_SOCKS_PASS_TRUSTED=CHANGE_ME
DNSCRYPT_SOCKS_USER_IOT=iot
DNSCRYPT_SOCKS_PASS_IOT=CHANGE_ME

# Tor control port authentication. backup-manager uses this to query
# circuit state (Live circuits panel, /api/metrics/tor, per-plane rotate,
# Tor runtime dashboard). The plain password below is hashed into
# tor/torrc at deploy time by ops/scripts/20-render-torrc.sh — do not
# edit tor/torrc by hand, change this value and re-run deploy instead.
TOR_CONTROL_PASSWORD=CHANGE_ME

# Alert delivery — all optional; leave blank to use a no-op receiver
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
ALERT_EMAIL_SMARTHOST=
ALERT_EMAIL_AUTH_USERNAME=
ALERT_EMAIL_AUTH_PASSWORD=
ALERT_EMAIL_REQUIRE_TLS=true
ALERT_EMAIL_ENABLED=

ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_TELEGRAM_ENABLED=

ALERT_DISCORD_WEBHOOK_URL=
ALERT_DISCORD_USERNAME=torhole
ALERT_DISCORD_ENABLED=

# Monitoring image versions (pin for reproducibility)
LOKI_IMAGE=grafana/loki:latest
ALLOY_IMAGE=grafana/alloy:latest

# External watchdog for Prometheus.
# Leave PROMETHEUS_WATCHDOG_URL empty to auto-discover via Docker network.
PROMETHEUS_WATCHDOG_URL=
PROMETHEUS_WATCHDOG_CONTAINER_NAME=prometheus
PROMETHEUS_WATCHDOG_NETWORK=pi-dns-warden_dns_int
PROMETHEUS_WATCHDOG_PORT=9090
PROMETHEUS_WATCHDOG_PATH=/-/healthy
PROMETHEUS_WATCHDOG_TIMEOUT_S=10

# Admin reverse proxy
# Web access selected by the setup wizard:
#   http         = simplest LAN access, protected with the admin login
#   https-local  = Caddy local CA; the setup receipt provides its certificate
#   https-custom = operator-supplied PEM certificate and private key
TORHOLE_WEB_MODE=https-local
# Derived automatically by ops/scripts/18-render-auth.sh. Do not normally edit.
TORHOLE_WEB_SCHEME=https
# REVERSE_PROXY_DOMAIN: your local DNS domain (must resolve on your LAN)
# Services are published as <host>.<REVERSE_PROXY_DOMAIN>.
REVERSE_PROXY_DOMAIN=CHANGE_ME   # e.g. home.internal or lan.example.com
REVERSE_PROXY_HTTP_PORT=80
# Where the public hostnames resolve in Pi-hole local DNS. Leave empty to use
# HOST_MGMT_IP (Caddy on this host). Set to an external front's IP (e.g. an
# NPM box) when this instance is proxied — keeps re-renders from clobbering it.
REVERSE_PROXY_TARGET_IP=

# Optional: path (inside backup-manager/pihole-exporter containers) to a CA
# bundle for verifying Pi-hole's internal self-signed TLS. Empty = accepted
# risk: no verification on the single-host internal bridge (audit S4/M3.3).
PIHOLE_CA_FILE=

# Export locally identifying Pi-hole top-client names/IPs to Prometheus.
# Disabled by default; enable only when the operational need outweighs the
# additional local privacy exposure and metric cardinality.
TORHOLE_EXPORT_CLIENT_METRICS=false

# Local monitoring history. These defaults retain 90 days of metrics and logs.
# Prometheus accepts values such as 30d or 90d. Loki uses an hour duration.
# Increasing retention consumes additional disk; reducing it does not recover
# space immediately and should be treated as a deliberate history policy.
TORHOLE_PROMETHEUS_RETENTION=90d
TORHOLE_LOKI_RETENTION=2160h

# Scheduled backups (backup-manager). Read live from this file — edit + save
# to change without restarting anything. INTERVAL_H=0 (default) disables the
# scheduler; e.g. 24 = one snapshot per day (keyed off the newest archive's
# age, so manual backups reset the clock). RETENTION keeps the newest N
# archives and deletes older ones after each successful scheduled run
# (0 = never delete).
TORHOLE_BACKUP_INTERVAL_H=0
TORHOLE_BACKUP_RETENTION=7

# Optional environment banner shown across the top of the admin UI.
# Read live from this file on every snapshot — edit + save to change the
# banner at runtime, no container restart needed. Empty text = no banner.
# Levels: critical (red), warning (amber), info (green; default).
TORHOLE_BANNER_TEXT=
TORHOLE_BANNER_LEVEL=info

# Public host labels under REVERSE_PROXY_DOMAIN. Change these to rename the
# Torhole lab without editing Caddy, Authelia, Pi-hole DNS, or UI links.
TORHOLE_HOST_TORHOLE=torhole
TORHOLE_HOST_AUTH=auth
TORHOLE_HOST_GRAFANA=grafana
TORHOLE_HOST_PROMETHEUS=prometheus
TORHOLE_HOST_ALERTMANAGER=alertmanager
TORHOLE_HOST_DOCKHAND=dockhand
TORHOLE_HOST_PIHOLE_TRUSTED=pihole-trusted
TORHOLE_HOST_PIHOLE_IOT=pihole-iot
TORHOLE_ALIAS_TORHOLE=th
TORHOLE_ALIAS_GRAFANA=gf
TORHOLE_ALIAS_PROMETHEUS=prom
TORHOLE_ALIAS_ALERTMANAGER=am
TORHOLE_ALIAS_DOCKHAND=dh
TORHOLE_ALIAS_PIHOLE_TRUSTED=pt
TORHOLE_ALIAS_PIHOLE_IOT=pi

# Optional extra host labels under REVERSE_PROXY_DOMAIN to point at HOST_MGMT_IP.
TORHOLE_DNS_HOSTS=

# Admin login credentials (Authelia)
# Leave AUTHELIA_SESSION_SECRET and AUTHELIA_STORAGE_ENCRYPTION_KEY blank
# to auto-generate during deploy.
TORHOLE_ADMIN_USER=admin
TORHOLE_ADMIN_PASSWORD=CHANGE_ME
AUTHELIA_IMAGE=authelia/authelia:latest
AUTHELIA_SESSION_SECRET=
AUTHELIA_STORAGE_ENCRYPTION_KEY=
# Generated by ops/scripts/18-render-auth.sh. Caddy presents this token to
# backup-manager so direct peer-container requests cannot bypass Authelia.
BACKUP_MANAGER_API_TOKEN=

# Optional extra Pi-hole local DNS records rendered during deploy/update/restore.
# Format: host=ip;fqdn=ip  (host without dot gets .${REVERSE_PROXY_DOMAIN} appended)
PIHOLE_LOCAL_DNS_RECORDS=

# torhole-api (admin control plane)
TORHOLE_API_IMAGE=torhole-api
TORHOLE_API_ROOT_DIR=/opt/pi-dns-warden
TORHOLE_API_PROJECT_NAME=pi-dns-warden
