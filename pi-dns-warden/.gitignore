# Secrets
.env
.env.*
!.env.example
!.env.quickstart.example

# Pi-hole data
pihole/*/etc-pihole/
pihole/*/etc-dnsmasq.d/

# Prometheus/Grafana persistent data (named volumes not stored here)
monitoring/prometheus/prometheus.runtime.yml

# Admin UI — built output lives at monitoring/caddy/admin-ui/ but is regenerated from
# source at deploy time. Keep it out of the repo so PRs don't churn on bundle
# hashes.
monitoring/caddy/admin-ui/

# Node / Vite / Playwright (monitoring/torhole-ui/)
monitoring/torhole-ui/node_modules/
monitoring/torhole-ui/.playwright-browsers/
monitoring/torhole-ui/test-results/
monitoring/torhole-ui/playwright-report/
monitoring/torhole-ui/dist/
monitoring/torhole-ui/.vite/

# Dashboard / Caddyfile rollback snapshots (.bak-YYYYMMDD...) produced by
# edit scripts during iteration. Kept locally for rollback, never committed.
monitoring/grafana/dashboards/*.bak-*.json
monitoring/caddy/*.bak-*
monitoring/caddy/Caddyfile.bak-*

# Recovery state written by backup-manager at runtime
restore-safety/
run/

# Runtime backup archives (large tarballs)
backups/
.torhole-revision

# Local hardware-validation and soak evidence. Review and redact before
# publishing individual reports intentionally.
validation/
torhole-soak-*.csv

# OS
.DS_Store
.idea/
.vscode/
*.swp
*~

# Logs
*.log

# Python bytecode
__pycache__/
*.pyc

# Rendered auth config
monitoring/authelia/configuration.yml
monitoring/authelia/users_database.yml
monitoring/caddy/auth-snippets.caddy
monitoring/caddy/tls-snippets.caddy
monitoring/caddy/topology-sites.caddy
monitoring/caddy/torhole-local-ca.crt
monitoring/caddy/tls/
