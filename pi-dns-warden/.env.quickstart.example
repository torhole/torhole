# torhole quick start — copy to .env, then:
#   docker compose -f docker-compose.quickstart.yml up -d

# Home is the default capability profile. Do not change this to advanced here;
# Advanced is configured by the same Setup wizard and the full deployment path.
TORHOLE_EDITION=home

# Curated Pi-hole lists managed by the Home installer. Supported values:
# stevenblack, oisd, adguard (comma-separated, at least one).
TORHOLE_BLOCKLISTS=stevenblack

# Pi-hole admin password (change this).
PIHOLE_PASSWORD=changeme

# Dashboard controls PIN and private helper secret. The installer generates
# both automatically; set strong unique values when configuring by hand.
CONTROL_PIN=change-this-pin
CONTROL_HELPER_TOKEN=change-this-long-random-token

# Your timezone (e.g. Europe/London, America/New_York).
TZ=UTC

# Host ports. Leave DNS_PORT=53 for normal use; if bring-up fails with
# "address already in use" (systemd-resolved on Linux owns :53), set it to
# 5353 and point your device at this host:5353, or free :53 first — see the
# quick-start README section.
DNS_PORT=53
WEB_PORT=8080
PIHOLE_WEB_PORT=8081

# LAN address that clients use for DNS. The installer detects this for you.
# Binding to the LAN address lets systemd-resolved keep its loopback listener.
BIND_ADDRESS=192.168.1.10
