{
  admin off
  metrics {
    per_host
  }
}

# Both files are rendered from .env before validation. They keep the site
# definitions identical across plain HTTP, Caddy-local HTTPS, and custom HTTPS.
import auth-snippets.caddy
import tls-snippets.caddy

(local_ca_download) {
  @local_ca path /torhole-local-ca.crt
  handle @local_ca {
    root * /srv
    header Content-Type application/x-x509-ca-cert
    header Content-Disposition "attachment; filename=torhole-local-ca.crt"
    file_server
  }
}

(recovery_health) {
  @recovery_health path /health/recovery
  handle @recovery_health {
    uri replace /health/recovery /health
    reverse_proxy backup-manager:8080
  }
}

(torhole_app) {
  @api path /api/*
  handle @api {
    reverse_proxy backup-manager:8080 {
      header_up Authorization "Bearer {$BACKUP_MANAGER_API_TOKEN}"
      flush_interval -1
    }
  }

  # /v2 was the development-era public prefix. Keep old bookmarks working,
  # but never generate or advertise versioned application URLs again.
  @versioned_root path /v2 /v2/
  handle @versioned_root {
    redir * / 308
  }

  # Compatibility for asset requests from an already-open pre-migration tab.
  # handle_path strips /v2 before looking in the canonical build directory.
  handle_path /v2/* {
    root * /srv/admin-ui
    try_files {path} /index.html
    file_server
  }

  @legacy_operate path /operate /operate.html /dns-planes /observability /recovery /system
  handle @legacy_operate {
    redir * /#/operate 308
  }

  @legacy_privacy path /resolver /resolver.html /resolver-chain
  handle @legacy_privacy {
    redir * /#/privacy 308
  }

  @legacy_configure path /access /access.html /edge-access
  handle @legacy_configure {
    redir * /#/configure 308
  }

  handle {
    root * /srv/admin-ui
    try_files {path} /index.html
    file_server
  }
}

# Named access is the normal entry point. TORHOLE_WEB_SCHEME is derived from
# TORHOLE_WEB_MODE by 18-render-auth.sh (http or https).
{$TORHOLE_WEB_SCHEME}://{$TORHOLE_HOST_AUTH}.{$REVERSE_PROXY_DOMAIN} {
  import tls_mode
  reverse_proxy authelia:9091
}

{$TORHOLE_WEB_SCHEME}://{$TORHOLE_HOST_TORHOLE}.{$REVERSE_PROXY_DOMAIN}, {$TORHOLE_WEB_SCHEME}://{$TORHOLE_ALIAS_TORHOLE}.{$REVERSE_PROXY_DOMAIN} {
  import tls_mode
  route {
    import local_ca_download
    import recovery_health
    import access_gate
    import torhole_app
  }
}

# Permanent LAN recovery entry point. It intentionally stays on HTTP so an
# incorrect hostname, DNS entry, or uploaded certificate cannot lock an
# operator out. It is protected with the Torhole admin credentials and should
# remain reachable only from the trusted management LAN.
http://{$HOST_MGMT_IP:127.0.0.1} {
  route {
    import local_ca_download
    import recovery_health
    import ip_access_gate
    import torhole_app
  }
}

{$TORHOLE_WEB_SCHEME}://{$TORHOLE_HOST_GRAFANA}.{$REVERSE_PROXY_DOMAIN}, {$TORHOLE_WEB_SCHEME}://{$TORHOLE_ALIAS_GRAFANA}.{$REVERSE_PROXY_DOMAIN} {
  import tls_mode
  route {
    import access_gate
    reverse_proxy 172.30.0.31:3000 {
      header_up X-WEBAUTH-USER {http.request.header.Remote-User}
      header_up X-WEBAUTH-NAME {http.request.header.Remote-Name}
      header_up X-WEBAUTH-EMAIL {http.request.header.Remote-Email}
      header_up X-Forwarded-User {http.request.header.Remote-User}
    }
  }
}

{$TORHOLE_WEB_SCHEME}://{$TORHOLE_HOST_PROMETHEUS}.{$REVERSE_PROXY_DOMAIN}, {$TORHOLE_WEB_SCHEME}://{$TORHOLE_ALIAS_PROMETHEUS}.{$REVERSE_PROXY_DOMAIN} {
  import tls_mode
  route {
    import access_gate
    reverse_proxy prometheus:9090
  }
}

{$TORHOLE_WEB_SCHEME}://{$TORHOLE_HOST_ALERTMANAGER}.{$REVERSE_PROXY_DOMAIN}, {$TORHOLE_WEB_SCHEME}://{$TORHOLE_ALIAS_ALERTMANAGER}.{$REVERSE_PROXY_DOMAIN} {
  import tls_mode
  route {
    import access_gate
    reverse_proxy alertmanager:9093
  }
}

{$TORHOLE_WEB_SCHEME}://{$TORHOLE_HOST_DOCKHAND}.{$REVERSE_PROXY_DOMAIN}, {$TORHOLE_WEB_SCHEME}://{$TORHOLE_ALIAS_DOCKHAND}.{$REVERSE_PROXY_DOMAIN} {
  import tls_mode
  route {
    import access_gate
    reverse_proxy dockhand:3000
  }
}

{$TORHOLE_WEB_SCHEME}://{$TORHOLE_HOST_PIHOLE_TRUSTED}.{$REVERSE_PROXY_DOMAIN}, {$TORHOLE_WEB_SCHEME}://{$TORHOLE_ALIAS_PIHOLE_TRUSTED}.{$REVERSE_PROXY_DOMAIN} {
  import tls_mode
  route {
    import access_gate
    @root path /
    redir @root /admin/ 302
    reverse_proxy pihole_trusted:80
  }
}

import topology-sites.caddy

http://:2019 {
  metrics /metrics
}
