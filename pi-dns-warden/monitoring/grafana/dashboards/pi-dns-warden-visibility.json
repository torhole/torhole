{
  "uid": "pidns-visibility",
  "title": "Pi DNS Warden - Visibility & Logs",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 8,
  "refresh": "15s",
  "tags": [
    "visibility",
    "logs",
    "dns",
    "investigation"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pi-hole telemetry floor",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "(min(pihole_exporter_up) * 100) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          },
          "noValue": "UNKNOWN"
        }
      },
      "description": "Worst authenticated Pi-hole API scrape across active topology planes."
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Log pipeline",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "(min(up{job=~\"loki|alloy\"}) * 100) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          },
          "noValue": "UNKNOWN"
        }
      },
      "description": "Worst current scrape state across Alloy and Loki."
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Proxy 5xx (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(caddy_http_request_duration_seconds_count{code=~\"5..\"}[1h])) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "noValue": "UNKNOWN"
        }
      },
      "description": "Server errors during the last hour. Investigate by host and logs when non-zero; a raw count is not a rate or error ratio."
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Proxy auth denials (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(caddy_http_request_duration_seconds_count{code=~\"401|403\"}[1h])) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "noValue": "UNKNOWN"
        }
      },
      "description": "Authentication denials during the last hour. Some denials are expected; investigate changes rather than treating every event as failure."
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Blocked queries (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(pihole_queries_blocked_total[1h])) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "noValue": "UNKNOWN"
        }
      },
      "description": "Queries blocked during the last hour. This is activity, not a health score."
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Edge scrape health",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "(avg(up{job=\"caddy\"}) * 100) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          },
          "noValue": "UNKNOWN"
        }
      }
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "Query status mix over selected range",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(10, sum by (status) (increase(pihole_query_status_total[$__range])))",
          "legendFormat": "{{status}}",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Query type mix over selected range",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 8,
        "y": 8,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(8, sum by (query_type) (increase(pihole_query_types_total[$__range])))",
          "legendFormat": "{{query_type}}",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "DNS outcomes by role",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (role) (rate(pihole_queries_cached_total[5m]))",
          "legendFormat": "Cached {{role}}",
          "refId": "A"
        },
        {
          "expr": "sum by (role) (rate(pihole_queries_forwarded_total[5m]))",
          "legendFormat": "Forwarded {{role}}",
          "refId": "B"
        },
        {
          "expr": "sum by (role) (rate(pihole_queries_blocked_total[5m]))",
          "legendFormat": "Blocked {{role}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "description": "Per-role cached, forwarded, and blocked rates. In single-LAN mode, trusted represents Flat LAN."
    },
    {
      "id": 18,
      "type": "logs",
      "title": "Control plane logs",
      "datasource": {
        "type": "loki",
        "uid": "LOKI"
      },
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "expr": "{container=~\"reverse-proxy|prometheus|grafana|alertmanager|loki|alloy|dockhand|blackbox-exporter|pihole-exporter\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "timeFrom": "30m",
      "description": "Recent control-plane logs for diagnosis (30-minute panel range). Raw resolver/client logs are intentionally excluded from the default dashboard."
    },
    {
      "id": 19,
      "type": "stat",
      "title": "Loki ingest rate",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(loki_distributor_lines_received_total[5m])) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "lps",
          "min": 0,
          "noValue": "UNKNOWN"
        }
      },
      "description": "Observed log ingest volume. Quiet networks may legitimately be near zero; component health is reported separately."
    },
    {
      "id": 20,
      "type": "piechart",
      "title": "Reply types over selected range",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 16,
        "y": 8,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(8, sum by (reply) (increase(pihole_query_replies_total[$__range])))",
          "refId": "A",
          "legendFormat": "{{reply}}",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "values": [
            "percent"
          ]
        },
        "pieType": "donut",
        "displayLabels": [
          "percent"
        ],
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "description": "DNS reply kinds reported by Pi-hole (IP, CNAME, NODATA, NXDOMAIN, etc). Sits naturally next to Query status and Query type mix."
    },
    {
      "id": 24,
      "type": "stat",
      "title": "Write failures/s",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 8,
        "y": 4,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(loki_write_failures_logged_total[5m])) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "decimals": 2,
          "noValue": "UNKNOWN"
        }
      },
      "description": "Loki write failures per second. Any sustained non-zero value warrants checking Loki and Alloy logs.",
      "links": [
        {
          "title": "Open the operator guide",
          "url": "https://github.com/torhole/torhole/blob/main/pi-dns-warden/docs/deploy-reference.md",
          "targetBlank": true
        }
      ]
    },
    {
      "id": 25,
      "type": "stat",
      "title": "Discarded bytes/s",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(loki_discarded_bytes_total[5m])) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          },
          "noValue": "UNKNOWN"
        }
      },
      "description": "Bytes per second discarded by Loki. Check Loki reason labels and limits when non-zero.",
      "links": [
        {
          "title": "Open the operator guide",
          "url": "https://github.com/torhole/torhole/blob/main/pi-dns-warden/docs/deploy-reference.md",
          "targetBlank": true
        }
      ]
    }
  ],
