{
  "uid": "pidns-visibility",
  "title": "Pi DNS Warden - Visibility & Logs",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 6,
  "refresh": "15s",
  "tags": [
    "visibility",
    "logs",
    "dns",
    "investigation"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pi-hole telemetry floor",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "min(pihole_exporter_up) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Log pipeline",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "avg(up{job=~\"loki|alloy\"}) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Proxy 5xx (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(caddy_http_request_duration_seconds_count{code=~\"5..\"}[1h]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Proxy auth denials (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(caddy_http_request_duration_seconds_count{code=~\"401|403\"}[1h]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Blocked queries (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(pihole_queries_blocked_total[1h]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Edge scrape health",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "avg(up{job=\"caddy\"}) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "Query status mix",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(10, sum by (status) (pihole_query_status_total))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Query type mix",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 6,
        "y": 4,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(8, sum by (query_type) (pihole_query_types_total))",
          "legendFormat": "{{query_type}}",
          "refId": "A"
        }
      ],
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 9,
      "type": "piechart",
      "title": "Upstream share",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (upstream) (pihole_upstream_queries_total{upstream!=\"blocklist\",upstream!=\"cache\"})",
          "legendFormat": "{{upstream}}",
          "refId": "A"
        }
      ],
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "DNS outcomes by role",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (role) (rate(pihole_queries_cached_total[5m]))",
          "legendFormat": "Cached {{role}}",
          "refId": "A"
        },
        {
          "expr": "sum by (role) (rate(pihole_queries_forwarded_total[5m]))",
          "legendFormat": "Forwarded {{role}}",
          "refId": "B"
        },
        {
          "expr": "sum by (role) (rate(pihole_queries_blocked_total[5m]))",
          "legendFormat": "Blocked {{role}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Upstream latency by role",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "avg by (role, upstream) (pihole_upstream_response_seconds{upstream!=\"blocklist\",upstream!=\"cache\"})",
          "legendFormat": "{{role}} -> {{upstream}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 15,
      "type": "bargauge",
      "title": "Top clients by query volume",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(10, sum by (client_name) (pihole_top_client_queries_total))",
          "legendFormat": "{{client_name}}",
          "refId": "A"
        }
      ],
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": false
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      }
    },
    {
      "id": 16,
      "type": "bargauge",
      "title": "Top upstreams by volume",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(8, sum by (upstream) (pihole_upstream_queries_total{upstream!=\"blocklist\",upstream!=\"cache\"}))",
          "legendFormat": "{{upstream}}",
          "refId": "A"
        }
      ],
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": false
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      }
    },
    {
      "id": 17,
      "type": "logs",
      "title": "Resolver logs",
      "datasource": {
        "type": "loki",
        "uid": "LOKI"
      },
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 12,
        "h": 10
      },
      "targets": [
        {
          "expr": "{container=~\"tor|dnscrypt-trusted|dnscrypt-iot|pihole_trusted|pihole_iot\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 18,
      "type": "logs",
      "title": "Control plane logs",
      "datasource": {
        "type": "loki",
        "uid": "LOKI"
      },
      "gridPos": {
        "x": 12,
        "y": 28,
        "w": 12,
        "h": 10
      },
      "targets": [
        {
          "expr": "{container=~\"reverse-proxy|prometheus|grafana|alertmanager|loki|alloy|dockhand|blackbox-exporter|pihole-exporter\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 19,
      "type": "stat",
      "title": "Loki ingest rate",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 38,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(loki_distributor_lines_received_total[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "green",
                "value": 5
              }
            ]
          },
          "unit": "lps"
        }
      },
      "description": "Log lines per second arriving at Loki. If this drops to 0, the log pipeline (Alloy \u2192 Loki) is broken even if the 'Log pipeline' health check looks green."
    },
    {
      "id": 20,
      "type": "piechart",
      "title": "Reply types mix",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 18,
        "y": 4,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(8, sum by (reply) (pihole_query_replies_total))",
          "refId": "A",
          "legendFormat": "{{reply}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "values": [
            "percent"
          ]
        },
        "pieType": "donut",
        "displayLabels": [
          "percent"
        ],
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "description": "DNS reply kinds reported by Pi-hole (IP, CNAME, NODATA, NXDOMAIN, etc). Sits naturally next to Query status and Query type mix."
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Log lines (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 4,
        "y": 38,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(loki_distributor_lines_received_total[1h]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "description": "Total log lines shipped to Loki in the last hour."
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Active streams",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 8,
        "y": 38,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(loki_ingester_memory_streams)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "description": "Active log streams held in the Loki ingester memory."
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Chunks stored/s",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 38,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(loki_ingester_chunks_stored_total[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "decimals": 2
        }
      },
      "description": "Rate of chunks flushed to storage. A healthy sign that ingester is not stuck."
    },
    {
      "id": 24,
      "type": "stat",
      "title": "Write failures/s",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 16,
        "y": 38,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(loki_write_failures_logged_total[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "decimals": 2
        }
      },
      "description": "Loki write failures per second. Should sit at 0."
    },
    {
      "id": 25,
      "type": "stat",
      "title": "Discarded bytes/s",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 20,
        "y": 38,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(loki_discarded_bytes_total[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "description": "Bytes Loki had to discard (rate limits, too-old, too-far-behind)."
    }
  ],
