{
  "uid": "pidns-platform",
  "title": "Pi DNS Warden - Edge & Egress",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 4,
  "refresh": "15s",
  "tags": [
    "dns",
    "edge",
    "caddy",
    "egress",
    "observability"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 6,
      "type": "stat",
      "title": "Reverse proxy edge",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "(avg_over_time(probe_success{job=\"blackbox-monitoring-tcp\",instance=~\"reverse-proxy:(80|443)\"}[5m]) * 100) or on() vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          },
          "noValue": "UNKNOWN"
        }
      },
      "description": "Current five-minute TCP reachability for the configured HTTP or HTTPS edge."
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Tor egress verification",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "torhole_leak_test_pass or on() vector(-1)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "FAIL",
                  "color": "red",
                  "index": 1
                },
                "1": {
                  "text": "PASS · DNS exits via Tor",
                  "color": "green",
                  "index": 2
                },
                "-1": {
                  "text": "UNKNOWN",
                  "color": "gray",
                  "index": 0
                }
              }
            }
          ],
          "noValue": "UNKNOWN"
        }
      },
      "description": "PASS means the scheduled compatibility-named leak test sent an independent request through Tor SOCKS and the remote IsTor check observed a Tor exit. It does not trace a DNS query through Pi-hole or dnscrypt. UNKNOWN is not healthy.",
      "links": [
        {
          "title": "Verify the privacy path",
          "url": "https://github.com/torhole/torhole/blob/main/pi-dns-warden/docs/privacy-model.md#network-isolation-verification",
          "targetBlank": true
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Edge request rate by host",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (host) (rate(caddy_http_requests_total{host!=\"\"}[5m]))",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "description": "Caddy request rate for the configured edge. It represents HTTP or HTTPS according to deployment mode."
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Proxy latency p95 by host",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, host) (rate(caddy_http_request_duration_seconds_bucket{host!=\"\"}[5m])))",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "description": "Five-minute p95 request latency per host. Interpret low-volume hosts cautiously because sparse histograms produce noisy quantiles."
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Core services reachability",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "avg_over_time(up{job=~\"node|cadvisor|prometheus|blackbox-exporter|caddy\"}[5m]) * 100",
          "legendFormat": "{{job}}",
          "refId": "A"
        },
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-monitoring-tcp\",instance=~\"reverse-proxy:(80|443)|grafana:3000|alertmanager:9093\"}[5m]) * 100",
          "legendFormat": "{{instance}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "description": "Metrics producer and configured blackbox-target reachability. Missing rows are unknown; use Control Room for current aggregate state."
    },
    {
      "id": 18,
      "type": "gauge",
      "title": "Proxy upstream health floor",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "min(caddy_reverse_proxy_upstreams_healthy) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "noValue": "UNKNOWN"
        }
      },
      "description": "Worst current Caddy upstream state. This reflects Caddy health state, including passive failures; active health checks are not configured.",
      "links": [
        {
          "title": "Open the operator guide",
          "url": "https://github.com/torhole/torhole/blob/main/pi-dns-warden/docs/deploy-reference.md",
          "targetBlank": true
        }
      ]
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Tor node and edge traffic",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{name=\"reverse-proxy\"}[5m]))",
          "legendFormat": "Reverse proxy RX",
          "refId": "A"
        },
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{name=\"reverse-proxy\"}[5m]))",
          "legendFormat": "Reverse proxy TX",
          "refId": "B"
        },
        {
          "expr": "sum(rate(container_network_receive_bytes_total{name=\"tor\"}[5m]))",
          "legendFormat": "Tor RX",
          "refId": "C"
        },
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{name=\"tor\"}[5m]))",
          "legendFormat": "Tor TX",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "description": "Reverse-proxy and Tor container-interface traffic for correlation. These are separate workloads, not shares of one total."
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Reverse proxy upstream health",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "caddy_reverse_proxy_upstreams_healthy",
          "refId": "A",
          "legendFormat": "{{upstream}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never"
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "description": "Per-upstream state reported by Caddy. 1 is available and 0 is marked down; current configuration relies on passive failure state."
    }
  ],
