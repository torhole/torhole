      "title": "Control Room",
      "type": "link",
      "url": "/d/pidns-control",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": true,
      "asDropdown": false
    },
    {
      "title": "DNS Path",
      "type": "link",
      "url": "/d/pidns-path",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": true,
      "asDropdown": false
    },
    {
      "title": "Tor Flow",
      "type": "link",
      "url": "/d/pidns-torflow",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": true,
      "asDropdown": false
    },
    {
      "title": "Edge & Egress",
      "type": "link",
      "url": "/d/pidns-platform",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": true,
      "asDropdown": false
    },
    {
      "title": "Visibility & Logs",
      "type": "link",
      "url": "/d/pidns-visibility",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": true,
      "asDropdown": false
    },
    {
      "title": "Host Infrastructure",
      "type": "link",
      "url": "/d/pidns-host",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": true,
      "asDropdown": false
    }
  ]
}
