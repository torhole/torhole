{
  "uid": "pidns-control",
  "title": "Pi DNS Warden - Control Room",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 8,
  "refresh": "15s",
  "tags": [
    "dns",
    "tor",
    "operations",
    "overview"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active alerts",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "noValue": "UNKNOWN"
        }
      },
      "description": "Number of firing Prometheus alerts. Zero is clean; open the operator guide and Alertmanager when non-zero.",
      "links": [
        {
          "title": "Open the operator guide",
          "url": "https://github.com/torhole/torhole/blob/main/pi-dns-warden/docs/deploy-reference.md",
          "targetBlank": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Reverse proxy edge",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "(avg_over_time(probe_success{job=\"blackbox-monitoring-tcp\",instance=~\"reverse-proxy:(80|443)\"}[5m]) * 100) or on() vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          },
          "noValue": "UNKNOWN"
        }
      },
      "description": "Five-minute TCP reachability for the configured HTTP or HTTPS reverse-proxy edge."
    },
    {
      "id": 3,
      "type": "stat",
      "title": "DNS availability floor",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "(min(avg_over_time(probe_success{job=~\"blackbox-dns-udp-pihole|blackbox-dns-tcp-dnscrypt|blackbox-tor-socks\"}[5m])) * 100) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          },
          "noValue": "UNKNOWN"
        }
      },
      "description": "Worst configured DNS/SOCKS probe success. This measures availability, not Tor egress; see Tor egress verification."
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Tor egress (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(container_network_transmit_bytes_total{name=\"tor\"}[1h])) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "noValue": "UNKNOWN"
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Blocked ratio (15m)",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "(100 * (sum(increase(pihole_queries_blocked_total[15m])) / clamp_min(sum(increase(pihole_queries_total[15m])), 1))) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "noValue": "UNKNOWN"
        }
      },
      "description": "Traffic characteristic, not health: a high block ratio can be intentional and zero can mean either quiet traffic or disabled lists."
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Log pipeline",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "(min(up{job=~\"loki|alloy\"}) * 100) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          },
          "noValue": "UNKNOWN"
        }
      },
      "description": "Worst current scrape state across Alloy and Loki. This checks components; ingest volume is shown in Visibility & Logs."
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Pi-hole telemetry floor",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "(min(pihole_exporter_up) * 100) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 66
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          },
          "unit": "percent",
          "noValue": "UNKNOWN"
        }
      },
      "description": "Worst authenticated Pi-hole API scrape across active planes (one in single-LAN, two in VLAN mode). Missing telemetry is unhealthy."
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Tor egress verification",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 4,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "torhole_leak_test_pass or on() vector(-1)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "FAIL",
                  "color": "red",
                  "index": 1
                },
                "1": {
                  "text": "PASS · DNS exits via Tor",
                  "color": "green",
                  "index": 2
                },
                "-1": {
                  "text": "UNKNOWN",
                  "color": "gray",
                  "index": 0
                }
              }
            }
          ],
          "noValue": "UNKNOWN"
        }
      },
      "description": "PASS means the scheduled compatibility-named leak test sent an independent request through Tor SOCKS and the remote IsTor check observed a Tor exit. It does not trace a DNS query through Pi-hole or dnscrypt. UNKNOWN is not healthy.",
      "links": [
        {
          "title": "Verify the privacy path",
          "url": "https://github.com/torhole/torhole/blob/main/pi-dns-warden/docs/privacy-model.md#network-isolation-verification",
          "targetBlank": true
        }
      ]
    },
    {
      "id": 9,
      "type": "piechart",
      "title": "DNS disposition over selected range",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(increase(pihole_queries_cached_total[$__range])) or vector(0)",
          "legendFormat": "Cached",
          "refId": "A",
          "instant": true,
          "range": false
        },
        {
          "expr": "sum(increase(pihole_queries_forwarded_total[$__range])) or vector(0)",
          "legendFormat": "Forwarded",
          "refId": "B",
          "instant": true,
          "range": false
        },
        {
          "expr": "sum(increase(pihole_queries_blocked_total[$__range])) or vector(0)",
          "legendFormat": "Blocked",
          "refId": "C",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "id": 10,
      "type": "piechart",
      "title": "HTTP status mix over selected range",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (code) (increase(caddy_http_request_duration_seconds_count[$__range]))",
          "legendFormat": "{{code}}",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Chain reachability by hop",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-monitoring-tcp\",instance=~\"reverse-proxy:(80|443)\"}[5m]) * 100",
          "legendFormat": "Reverse proxy edge",
          "refId": "A"
        },
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-dns-udp-pihole\"}[5m]) * 100",
          "legendFormat": "Pi-hole {{instance}}",
          "refId": "B"
        },
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-dns-tcp-dnscrypt\"}[5m]) * 100",
          "legendFormat": "dnscrypt {{instance}}",
          "refId": "C"
        },
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-tor-socks\"}[5m]) * 100",
          "legendFormat": "Tor SOCKS",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "description": "Historical reachability for configured active targets. Port/DNS success is not a substitute for Tor egress verification."
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Tor egress verification age",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 8,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "torhole_leak_test_age_seconds or on() vector(-1)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "gray",
                "value": null
              },
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "orange",
                "value": 3600
              },
              {
                "color": "red",
                "value": 7200
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "-1": {
                  "text": "UNKNOWN",
                  "color": "gray",
                  "index": 0
                }
              }
            }
          ],
          "noValue": "UNKNOWN"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "description": "Age of the latest scheduled compatibility-named leak test. Red at two hours (four missed 30-minute runs). The test covers an independent SOCKS request, not DNS-path tracing; UNKNOWN means it has never completed.",
      "links": [
        {
          "title": "Verify the privacy path",
          "url": "https://github.com/torhole/torhole/blob/main/pi-dns-warden/docs/privacy-model.md#network-isolation-verification",
          "targetBlank": true
        }
      ]
    },
    {
      "id": 17,
      "type": "state-timeline",
      "title": "Service state timeline",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox-monitoring-tcp\",instance=~\"reverse-proxy:(80|443)|grafana:3000|alertmanager:9093\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        },
        {
          "expr": "probe_success{job=\"blackbox-dns-udp-pihole\"}",
          "legendFormat": "{{instance}}",
          "refId": "B"
        },
        {
          "expr": "probe_success{job=\"blackbox-dns-tcp-dnscrypt\"}",
          "legendFormat": "{{instance}}",
          "refId": "C"
        },
        {
          "expr": "probe_success{job=\"blackbox-tor-socks\"}",
          "legendFormat": "tor:9050",
          "refId": "D"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "mergeValues": true,
        "rowHeight": 0.9,
        "showValue": "never"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "down"
                },
                "1": {
                  "color": "green",
                  "text": "up"
                }
              },
              "type": "value"
            }
          ]
        }
      },
      "description": "Configured blackbox targets only. Missing rows are unknown, not healthy."
    },
    {
      "id": 18,
      "type": "stat",
      "title": "Core scrape freshness",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "max(((time() - timestamp(up{job=~\"pihole-exporter|node|cadvisor|caddy|loki|alloy|blackbox-exporter|torhole-tor\"})) + ((1 - up{job=~\"pihole-exporter|node|cadvisor|caddy|loki|alloy|blackbox-exporter|torhole-tor\"}) * 1000000000)) or vector((8 - scalar(count(count by (job) (up{job=~\"pihole-exporter|node|cadvisor|caddy|loki|alloy|blackbox-exporter|torhole-tor\"})))) * 1000000000)) or vector(1000000000)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 60
              },
              {
                "color": "red",
                "value": 300
              }
            ]
          },
          "unit": "s",
          "noValue": "UNKNOWN"
        }
      },
      "description": "Maximum age of the latest scrape sample across core jobs. Any current up=0 or total absence is forced red rather than appearing fresh.",
      "links": [
        {
          "title": "Open the operator guide",
          "url": "https://github.com/torhole/torhole/blob/main/pi-dns-warden/docs/deploy-reference.md",
          "targetBlank": true
        }
      ]
    },
    {
      "id": 19,
      "type": "state-timeline",
      "title": "Firing alerts (24h)",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "ALERTS{alertstate=\"firing\"}",
          "refId": "A",
          "legendFormat": "{{alertname}}"
        }
      ],
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "alignValue": "left",
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single"
        },
        "rowHeight": 0.9
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 80
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "",
                  "color": "red",
                  "index": 0
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "firing",
                  "color": "red",
                  "index": 1
                }
              }
            }
          ]
        }
      },
      "description": "Prometheus firing-alert history over the last 24 hours. No data is unknown unless Active alerts is a current green zero.",
      "timeFrom": "24h"
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Youngest core-container uptime",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "time() - max(container_start_time_seconds{name=~\"tor|reverse-proxy|pihole_(trusted|iot)|dnscrypt-(trusted|iot)\"})",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
