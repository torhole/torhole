{
  "uid": "pidns-control",
  "title": "Pi DNS Warden - Control Room",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 7,
  "refresh": "15s",
  "tags": [
    "dns",
    "tor",
    "operations",
    "overview"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active alerts",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(ALERTS{alertstate=\"firing\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Reverse proxy HTTPS",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-monitoring-tcp\",instance=\"reverse-proxy:443\"}[5m]) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "DNS chain floor",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "min(avg_over_time(probe_success{job=~\"blackbox-dns-udp-pihole|blackbox-dns-tcp-dnscrypt|blackbox-tor-socks\"}[5m])) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Tor egress (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(container_network_transmit_bytes_total{name=\"tor\"}[1h]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Blocked ratio (15m)",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "100 * (sum(increase(pihole_queries_blocked_total[15m])) / clamp_min(sum(increase(pihole_queries_total[15m])), 1))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 15
              },
              {
                "color": "red",
                "value": 35
              }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Log pipeline",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "avg(up{job=~\"loki|alloy\"}) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Pi-hole telemetry floor",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "min(pihole_exporter_up) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 66
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          },
          "unit": "percent"
        }
      },
      "description": "Worst-case Pi-hole exporter availability across the three planes. Red if any plane lost its scrape target."
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Traffic share now",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 6,
        "y": 4,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{name=\"reverse-proxy\"}[5m]))",
          "legendFormat": "Edge ingress",
          "refId": "A"
        },
        {
          "expr": "sum(rate(container_network_receive_bytes_total{name=~\"pihole_(trusted|iot)\"}[5m]))",
          "legendFormat": "Pi-hole ingress",
          "refId": "B"
        },
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{name=~\"dnscrypt-(trusted|iot)\"}[5m]))",
          "legendFormat": "Resolver to Tor",
          "refId": "C"
        },
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{name=\"tor\"}[5m]))",
          "legendFormat": "Tor egress",
          "refId": "D"
        }
      ],
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      }
    },
    {
      "id": 9,
      "type": "piechart",
      "title": "DNS disposition now",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(pihole_queries_cached_total[5m]))",
          "legendFormat": "Cached",
          "refId": "A"
        },
        {
          "expr": "sum(rate(pihole_queries_forwarded_total[5m]))",
          "legendFormat": "Forwarded",
          "refId": "B"
        },
        {
          "expr": "sum(rate(pihole_queries_blocked_total[5m]))",
          "legendFormat": "Blocked",
          "refId": "C"
        }
      ],
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "id": 10,
      "type": "piechart",
      "title": "HTTP status mix",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 18,
        "y": 4,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (code) (rate(caddy_http_request_duration_seconds_count[5m]))",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ],
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Chain reachability by hop",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-monitoring-tcp\",instance=\"reverse-proxy:443\"}[5m]) * 100",
          "legendFormat": "Reverse proxy 443",
          "refId": "A"
        },
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-dns-udp-pihole\"}[5m]) * 100",
          "legendFormat": "Pi-hole {{instance}}",
          "refId": "B"
        },
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-dns-tcp-dnscrypt\"}[5m]) * 100",
          "legendFormat": "dnscrypt {{instance}}",
          "refId": "C"
        },
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-tor-socks\"}[5m]) * 100",
          "legendFormat": "Tor SOCKS",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Resolver demand vs Tor edge",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{name=~\"dnscrypt-(trusted|iot)\"}[5m]))",
          "legendFormat": "dnscrypt to Tor",
          "refId": "A"
        },
        {
          "expr": "sum(rate(container_network_receive_bytes_total{name=\"tor\"}[5m]))",
          "legendFormat": "Tor RX",
          "refId": "B"
        },
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{name=\"tor\"}[5m]))",
          "legendFormat": "Tor TX",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Critical stack restarts (24h)",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (name) (increase(container_restart_count_total{name=~\"tor|dnscrypt-(trusted|iot)|pihole_(trusted|iot)|prometheus|grafana|alertmanager|blackbox-exporter|dockhand|reverse-proxy|loki|alloy|pihole-exporter\"}[24h]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 17,
      "type": "state-timeline",
      "title": "Service state timeline",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox-monitoring-tcp\",instance=~\"reverse-proxy:443|grafana:3000|alertmanager:9093|dockhand:3000\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        },
        {
          "expr": "probe_success{job=\"blackbox-dns-udp-pihole\"}",
          "legendFormat": "{{instance}}",
          "refId": "B"
        },
        {
          "expr": "probe_success{job=\"blackbox-dns-tcp-dnscrypt\"}",
          "legendFormat": "{{instance}}",
          "refId": "C"
        },
        {
          "expr": "probe_success{job=\"blackbox-tor-socks\"}",
          "legendFormat": "tor:9050",
          "refId": "D"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "mergeValues": true,
        "rowHeight": 0.9,
        "showValue": "never"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "down"
                },
                "1": {
                  "color": "green",
                  "text": "up"
                }
              },
              "type": "value"
            }
          ]
        }
      }
    },
    {
      "id": 18,
      "type": "stat",
      "title": "Scrape freshness",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "max(time() - timestamp(up{job=~\"pihole-exporter|node|cadvisor|caddy|loki|alloy|blackbox-exporter\"}))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 60
              },
              {
                "color": "red",
                "value": 300
              }
            ]
          },
          "unit": "s"
        }
      },
      "description": "Age of the oldest successful scrape across core targets. If this climbs, some scrape job is failing silently."
    },
    {
      "id": 19,
      "type": "state-timeline",
      "title": "Firing alerts (24h)",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "ALERTS{alertstate=\"firing\"}",
          "refId": "A",
          "legendFormat": "{{alertname}}"
        }
      ],
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "alignValue": "left",
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single"
        },
        "rowHeight": 0.9
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 80
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "",
                  "color": "red",
                  "index": 0
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "firing",
                  "color": "red",
                  "index": 1
                }
              }
            }
          ]
        }
      },
      "description": "Which alert rules were firing when, over the last 24 hours. Empty strip means the stack was clean."
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Stack uptime",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 6,
        "y": 36,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "time() - min(container_start_time_seconds{name=~\"tor|reverse-proxy|pihole_(trusted|iot)|dnscrypt-(trusted|iot)\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "description": "Minimum uptime across Torhole core containers. A low value means something just restarted."
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Scrape targets up",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 36,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "100 * sum(up) / count(up)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        }
      },
      "description": "Percent of Prometheus scrape targets that are currently up."
    },
    {
      "id": 22,
      "type": "stat",
      "title": "TSDB head series",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 18,
        "y": 36,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "prometheus_tsdb_head_series",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "description": "Total time series in Prometheus's head block. Sudden growth can indicate label cardinality explosion."
    }
  ],
  "links": [
    {
      "title": "Control Room",
      "type": "link",
      "url": "/d/pidns-control",
