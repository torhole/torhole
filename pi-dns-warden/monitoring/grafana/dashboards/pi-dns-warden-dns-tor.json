{
  "uid": "pidns-path",
  "title": "Pi DNS Warden - DNS Path",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 7,
  "refresh": "15s",
  "tags": [
    "dns",
    "path",
    "latency",
    "flow"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Trusted Pi-hole UDP",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-dns-udp-pihole\",instance=\"pihole_trusted:53\"}[5m]) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        }
      }
    },
