      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Path CPU cores used",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 8,
        "y": 36,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"tor|dnscrypt-(trusted|iot)|pihole_(trusted|iot)\"}[5m]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Path memory footprint",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 16,
        "y": 36,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (name) (container_memory_usage_bytes{name=~\"tor|dnscrypt-(trusted|iot)|pihole_(trusted|iot)\"})",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 18,
      "type": "gauge",
      "title": "DNS path health floor",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "min(avg_over_time(probe_success{job=~\"blackbox-dns-udp-pihole|blackbox-dns-tcp-dnscrypt\"}[5m])) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        }
      }
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Blocked ratio by role",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 44,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "100 * (sum by (role) (rate(pihole_queries_blocked_total[5m])) / clamp_min(sum by (role) (rate(pihole_queries_total[5m])), 0.001))",
          "legendFormat": "{{role}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Cache vs forwarded vs blocked by role",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 8,
        "y": 44,
        "w": 16,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (role) (rate(pihole_queries_cached_total[5m]))",
          "legendFormat": "Cached {{role}}",
          "refId": "A"
        },
        {
          "expr": "sum by (role) (rate(pihole_queries_forwarded_total[5m]))",
          "legendFormat": "Forwarded {{role}}",
          "refId": "B"
        },
        {
          "expr": "sum by (role) (rate(pihole_queries_blocked_total[5m]))",
          "legendFormat": "Blocked {{role}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Cache hit ratio by role",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 52,
        "w": 24,
        "h": 7
      },
      "targets": [
        {
          "expr": "100 * (sum by (role) (rate(pihole_queries_cached_total[5m])) / clamp_min(sum by (role) (rate(pihole_queries_total[5m])), 0.001))",
          "refId": "A",
          "legendFormat": "{{role}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never"
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "description": "Share of queries answered from Pi-hole's cache per plane. Higher is better \u2014 every cache hit is a query we don't have to forward through dnscrypt \u2192 Tor."
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Total queries/sec",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(pihole_queries_total[1m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "qps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "description": "Combined DNS query rate across all three planes. Live pulse of how busy the stack is."
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Pi-hole cache entries",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 8,
        "y": 4,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(pihole_dns_cache_entries{state=\"valid\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "description": "Total valid cache entries across the three Pi-hole instances. Every hit here is a query we didn't have to forward through Tor."
    }
