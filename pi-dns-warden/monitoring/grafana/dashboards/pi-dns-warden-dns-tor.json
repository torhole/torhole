    {
      "id": 10,
      "type": "timeseries",
      "title": "dnscrypt probe latency by DNS plane",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "avg_over_time(probe_duration_seconds{job=\"blackbox-dns-tcp-dnscrypt\"}[5m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
