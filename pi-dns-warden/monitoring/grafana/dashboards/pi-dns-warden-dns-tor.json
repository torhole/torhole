              },
              {
                "color": "green",
                "value": 99
              }
            ]
          },
          "noValue": "UNKNOWN"
        }
      },
      "description": "Five-minute probe success for configured targets only. Single-LAN has one active plane; VLAN mode has Trusted and IoT."
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Pi-hole UDP success by DNS plane",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
