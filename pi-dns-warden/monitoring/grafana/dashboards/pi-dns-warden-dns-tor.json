{
  "uid": "pidns-path",
  "title": "Pi DNS Warden - DNS Path",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 8,
  "refresh": "15s",
  "tags": [
    "dns",
    "path",
    "latency",
    "flow"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pi-hole UDP by active plane",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "(avg_over_time(probe_success{job=\"blackbox-dns-udp-pihole\"}[5m]) * 100) or on() vector(0)",
          "legendFormat": "{{instance}}",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          },
          "noValue": "UNKNOWN"
        }
      },
      "description": "Five-minute probe success for configured targets only. Single-LAN has one active plane; VLAN mode has Trusted and IoT."
    },
    {
      "id": 4,
      "type": "stat",
      "title": "dnscrypt TCP by active plane",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "expr": "(avg_over_time(probe_success{job=\"blackbox-dns-tcp-dnscrypt\"}[5m]) * 100) or on() vector(0)",
          "legendFormat": "{{instance}}",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
