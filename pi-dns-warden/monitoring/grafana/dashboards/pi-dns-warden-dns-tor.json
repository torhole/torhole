    {
      "id": 9,
      "type": "timeseries",
      "title": "Pi-hole probe latency by DNS plane",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "avg_over_time(probe_duration_seconds{job=\"blackbox-dns-udp-pihole\"}[5m])",
          "legendFormat": "{{instance}}",
