      "title": "Pi-hole query rate by role",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (role) (rate(pihole_queries_total[5m]))",
          "legendFormat": "{{role}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
