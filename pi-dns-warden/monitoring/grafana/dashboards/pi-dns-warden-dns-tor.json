      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Pi-hole query rate by DNS plane",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (role) (rate(pihole_queries_total[5m]))",
          "legendFormat": "{{role}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "description": "In single-LAN mode, the trusted role is the Flat LAN plane."
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Forwarded DNS queries by DNS plane",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (role) (rate(pihole_queries_forwarded_total[5m]))",
          "legendFormat": "{{role}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "description": "In single-LAN mode, the trusted role is the Flat LAN plane."
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Pi-hole admin reachability by DNS plane",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-pihole-http\"}[5m]) * 100",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Path CPU cores used",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"tor|dnscrypt-(trusted|iot)|pihole_(trusted|iot)\"}[5m]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Path memory footprint",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (name) (container_memory_usage_bytes{name=~\"tor|dnscrypt-(trusted|iot)|pihole_(trusted|iot)\"})",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 18,
      "type": "stat",
      "title": "Tor egress verification",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 9,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "expr": "torhole_leak_test_pass or on() vector(-1)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "FAIL",
                  "color": "red",
                  "index": 1
                },
                "1": {
                  "text": "PASS · DNS exits via Tor",
                  "color": "green",
                  "index": 2
                },
                "-1": {
                  "text": "UNKNOWN",
                  "color": "gray",
                  "index": 0
                }
              }
            }
          ],
          "noValue": "UNKNOWN"
        }
      },
      "description": "PASS means the scheduled compatibility-named leak test sent an independent request through Tor SOCKS and the remote IsTor check observed a Tor exit. It does not trace a DNS query through Pi-hole or dnscrypt. UNKNOWN is not healthy.",
      "links": [
        {
          "title": "Verify the privacy path",
          "url": "https://github.com/torhole/torhole/blob/main/pi-dns-warden/docs/privacy-model.md#network-isolation-verification",
          "targetBlank": true
        }
      ]
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Blocked ratio by DNS plane",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "100 * (sum by (role) (rate(pihole_queries_blocked_total[5m])) / clamp_min(sum by (role) (rate(pihole_queries_total[5m])), 0.001))",
          "legendFormat": "{{role}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "description": "In single-LAN mode, the trusted role is the Flat LAN plane."
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Cache vs forwarded vs blocked by DNS plane",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 44,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (role) (rate(pihole_queries_cached_total[5m]))",
          "legendFormat": "Cached {{role}}",
          "refId": "A"
        },
        {
          "expr": "sum by (role) (rate(pihole_queries_forwarded_total[5m]))",
          "legendFormat": "Forwarded {{role}}",
          "refId": "B"
        },
        {
          "expr": "sum by (role) (rate(pihole_queries_blocked_total[5m]))",
          "legendFormat": "Blocked {{role}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "description": "In single-LAN mode, the trusted role is the Flat LAN plane."
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Cache hit ratio by DNS plane",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 44,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "100 * (sum by (role) (rate(pihole_queries_cached_total[5m])) / clamp_min(sum by (role) (rate(pihole_queries_total[5m])), 0.001))",
          "refId": "A",
          "legendFormat": "{{role}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never"
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "description": "Share of queries answered from Pi-hole's cache per plane. Higher is better — every cache hit is a query we don't have to forward through dnscrypt → Tor. In single-LAN mode, the trusted role is the Flat LAN plane."
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Total queries/sec",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 14,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(pihole_queries_total[1m])) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "qps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "noValue": "UNKNOWN"
        }
      },
      "description": "Combined live query rate across active Pi-hole planes (one in single-LAN, two in VLAN mode)."
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Pi-hole cache entries",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 19,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(pihole_dns_cache_entries{state=\"valid\"}) or vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "noValue": "UNKNOWN"
        }
      },
      "description": "Valid cache entries across active Pi-hole instances. Missing telemetry is shown as zero and should be checked against Pi-hole probe health."
    }
