      "title": "Pi-hole admin reachability by VLAN",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-pihole-http\"}[5m]) * 100",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
