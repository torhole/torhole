    {
      "id": 9,
      "type": "timeseries",
      "title": "Tor ingress vs egress rate",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{name=\"tor\"}[5m]))",
          "legendFormat": "Tor RX",
          "refId": "A"
        },
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{name=\"tor\"}[5m]))",
          "legendFormat": "Tor TX",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Resolver traffic by active plane",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_network_transmit_bytes_total{name=~\"dnscrypt-(trusted|iot)\"}[5m]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "description": "Container-interface transmit rate for active dnscrypt resolvers. In single-LAN mode, the trusted label represents the Flat LAN plane. This is workload context, not Tor egress verification."
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Tor SOCKS reachability",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=\"blackbox-tor-socks\"}[5m]) * 100",
          "legendFormat": "Tor SOCKS",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "description": "TCP reachability of Tor SOCKS. A reachable port does not verify Tor egress; use Tor egress verification for the independent SOCKS check."
    },
