      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "down",
                  "color": "red",
                  "index": 0
                },
                "1": {
                  "text": "up",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ]
        }
      },
      "description": "1 if Tor believes the wider network is reachable, 0 if not. Read via GETINFO network-liveness."
    },
