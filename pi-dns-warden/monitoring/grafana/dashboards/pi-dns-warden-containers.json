    {
      "id": 19,
      "type": "gauge",
      "title": "Tor availability snapshot",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 8,
