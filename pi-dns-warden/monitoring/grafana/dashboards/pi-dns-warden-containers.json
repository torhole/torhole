{
  "uid": "pidns-torflow",
  "title": "Pi DNS Warden - Tor Flow & Runtime",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 5,
  "refresh": "15s",
  "tags": [
    "tor",
    "traffic",
    "runtime",
    "egress"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Tor RX rate",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 3,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{name=\"tor\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Tor TX rate",
