      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        }
      },
      "description": "Tor bootstrap progress 0-100 read from the control port. 100 = ready to carry traffic. Sourced live from /api/metrics/tor."
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Network liveness",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 5,
        "y": 44,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "expr": "tor_network_liveness",
