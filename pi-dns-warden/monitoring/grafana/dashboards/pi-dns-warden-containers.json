{
  "uid": "pidns-torflow",
  "title": "Pi DNS Warden - Tor Flow & Runtime",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 6,
  "refresh": "15s",
  "tags": [
    "tor",
    "traffic",
    "runtime",
    "egress"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Tor egress verification",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "torhole_leak_test_pass or on() vector(-1)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "FAIL",
                  "color": "red",
                  "index": 1
                },
                "1": {
                  "text": "PASS · DNS exits via Tor",
                  "color": "green",
                  "index": 2
                },
                "-1": {
                  "text": "UNKNOWN",
                  "color": "gray",
                  "index": 0
                }
              }
            }
          ],
          "noValue": "UNKNOWN"
        }
      },
      "description": "PASS means the scheduled compatibility-named leak test sent an independent request through Tor SOCKS and the remote IsTor check observed a Tor exit. It does not trace a DNS query through Pi-hole or dnscrypt. UNKNOWN is not healthy.",
      "links": [
        {
          "title": "Verify the privacy path",
          "url": "https://github.com/torhole/torhole/blob/main/pi-dns-warden/docs/privacy-model.md#network-isolation-verification",
          "targetBlank": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Tor egress verification age",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "torhole_leak_test_age_seconds or on() vector(-1)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "gray",
                "value": null
              },
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "orange",
                "value": 3600
              },
              {
                "color": "red",
                "value": 7200
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "-1": {
                  "text": "UNKNOWN",
                  "color": "gray",
                  "index": 0
                }
              }
            }
          ],
          "noValue": "UNKNOWN"
        }
      },
      "description": "Age of the latest scheduled compatibility-named leak test. Red at two hours (four missed 30-minute runs). The test covers an independent SOCKS request, not DNS-path tracing; UNKNOWN means it has never completed.",
      "links": [
        {
          "title": "Verify the privacy path",
          "url": "https://github.com/torhole/torhole/blob/main/pi-dns-warden/docs/privacy-model.md#network-isolation-verification",
          "targetBlank": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Tor control port",
      "datasource": {
        "type": "prometheus",
        "uid": "PROM"
      },
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "tor_control_port_up or on() vector(0)",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "min": 0,
          "max": 1,
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "unavailable",
                  "color": "red",
                  "index": 0
                },
                "1": {
                  "text": "connected",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "noValue": "UNKNOWN"
        }
      },
      "description": "Whether Prometheus can obtain authenticated Tor runtime data. A failed control-port scrape makes runtime metrics unknown.",
      "links": [
        {
          "title": "Verify the privacy path",
          "url": "https://github.com/torhole/torhole/blob/main/pi-dns-warden/docs/privacy-model.md#network-isolation-verification",
          "targetBlank": true
        }
      ]
    },
