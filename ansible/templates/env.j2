TZ={{ timezone }}
PARENT_IF={{ parent_iface }}
HOST_MGMT_IP={{ host_mgmt_ip }}
TRUSTED_VLAN_ID={{ trusted_vlan_id }}
IOT_VLAN_ID={{ iot_vlan_id }}
TRUSTED_PARENT={{ parent_iface }}{% if trusted_vlan_id != 1 %}.{{ trusted_vlan_id }}{% endif %}
IOT_PARENT={{ parent_iface }}.{{ iot_vlan_id }}
TRUSTED_SUBNET_CIDR={{ trusted_subnet_cidr }}
TRUSTED_GATEWAY={{ trusted_gateway }}
IOT_SUBNET_CIDR={{ iot_subnet_cidr }}
IOT_GATEWAY={{ iot_gateway }}
PIHOLE_TRUSTED_IP={{ pihole_trusted_ip }}
PIHOLE_IOT_IP={{ pihole_iot_ip }}
PIHOLE_TRUSTED_WEB_PORT={{ pihole_trusted_web_port }}
PIHOLE_TRUSTED_PASSWORD={{ pihole_passwords.trusted | quote }}
PIHOLE_IOT_PASSWORD={{ pihole_passwords.iot | quote }}
DNSCRYPT_RESOLVERS={{ dnscrypt_resolvers | join(',') }}
DNSCRYPT_CACHE_SIZE=8192
DNSCRYPT_CACHE_MIN_TTL=60
DNSCRYPT_CACHE_MAX_TTL=86400
DNSCRYPT_TIMEOUT_MS=5000
DNSCRYPT_KEEPALIVE_S=30
DNSCRYPT_SOCKS_USER_TRUSTED={{ dnscrypt_socks.trusted_user }}
DNSCRYPT_SOCKS_PASS_TRUSTED={{ dnscrypt_socks.trusted_pass }}
DNSCRYPT_SOCKS_USER_IOT={{ dnscrypt_socks.iot_user }}
DNSCRYPT_SOCKS_PASS_IOT={{ dnscrypt_socks.iot_pass }}
ALERT_EMAIL_TO={{ alert_email_to | default('') }}
ALERT_EMAIL_FROM={{ alert_email_from | default('') }}
ALERT_EMAIL_SMARTHOST={{ alert_email_smarthost | default('') }}
ALERT_EMAIL_AUTH_USERNAME={{ alert_email_auth_username | default('') }}
ALERT_EMAIL_AUTH_PASSWORD={{ alert_email_auth_password | default('') }}
ALERT_EMAIL_REQUIRE_TLS={{ alert_email_require_tls | default('true') }}
ALERT_TELEGRAM_BOT_TOKEN={{ alert_telegram_bot_token | default('') }}
ALERT_TELEGRAM_CHAT_ID={{ alert_telegram_chat_id | default('') }}
PROMETHEUS_WATCHDOG_URL={{ prometheus_watchdog_url | default('http://127.0.0.1:9090/-/healthy') }}
PROMETHEUS_WATCHDOG_TIMEOUT_S={{ prometheus_watchdog_timeout_s | default('10') }}
REVERSE_PROXY_DOMAIN={{ reverse_proxy_domain | default('home.arpa') }}
REVERSE_PROXY_HTTP_PORT={{ reverse_proxy_http_port | default('80') }}
